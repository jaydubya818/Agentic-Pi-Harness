{
  "name": "agentic-pi-harness",
  "version": "0.4.0",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "description": "Tier A agent harness proof on Pi: canonical golden path, deterministic replay, effect capture, and crash-safe artifacts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pi-harness": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest run --config vitest.bench.config.ts",
    "lint": "eslint --ext .ts src tests",
    "dev": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "hermes:bridge": "tsx src/cli/hermes-bridge.ts",
    "hermes:doctor": "tsx src/cli/hermes-doctor.ts",
    "hermes:demo": "tsx src/cli/hermes-demo.ts",
    "hermes:run": "tsx src/cli/hermes-run.ts",
    "hermes:smoke": "tsx src/cli/hermes-smoke.ts",
    "verify": "tsx src/cli/verify.ts",
    "replay": "tsx src/cli/replay.ts",
    "what-changed": "tsx src/cli/what-changed.ts",
    "golden:verify": "tsx src/cli/verify.ts ./goldens/canonical/tape.jsonl",
    "golden:replay": "tsx src/cli/replay.ts ./goldens/canonical/tape.jsonl",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "agent",
    "harness",
    "pi",
    "claude-code",
    "replay",
    "agentic"
  ],
  "license": "MIT"
}
