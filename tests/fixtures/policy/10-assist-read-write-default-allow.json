{
  "policyMode": "real",
  "policy": {
    "schemaVersion": 1,
    "defaultAction": "approve",
    "rules": [
      { "id": "allow-read", "action": "approve", "match": { "tool": "read_file", "mode": "assist" } },
      { "id": "allow-write", "action": "approve", "match": { "tool": "write_file", "mode": "assist" } }
    ]
  },
  "cases": [
    {
      "name": "assist read is approved by explicit rule",
      "decisionInput": {
        "toolCallId": "t1",
        "toolName": "read_file",
        "mode": "assist",
        "input": { "path": "tests/math.test.ts" },
        "policyDigest": "sha256:fixture-assist"
      },
      "expected": {
        "result": "approve",
        "provenanceMode": "real",
        "winningRuleId": "allow-read",
        "evaluationOrder": ["allow-read", "allow-write"]
      }
    },
    {
      "name": "assist write is approved by explicit rule",
      "decisionInput": {
        "toolCallId": "t2",
        "toolName": "write_file",
        "mode": "assist",
        "input": { "path": "tests/math.test.ts", "content": "patched" },
        "policyDigest": "sha256:fixture-assist"
      },
      "expected": {
        "result": "approve",
        "provenanceMode": "real",
        "winningRuleId": "allow-write",
        "evaluationOrder": ["allow-read", "allow-write"]
      }
    },
    {
      "name": "unknown tool falls through to explicit default approve",
      "decisionInput": {
        "toolCallId": "t3",
        "toolName": "stat_file",
        "mode": "assist",
        "input": { "path": "tests/math.test.ts" },
        "policyDigest": "sha256:fixture-assist"
      },
      "expected": {
        "result": "approve",
        "provenanceMode": "real",
        "winningRuleId": null,
        "evaluationOrder": ["allow-read", "allow-write"]
      }
    }
  ]
}
